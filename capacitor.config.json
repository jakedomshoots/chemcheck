{
  "appId": "com.chemcheck.app",
  "appName": "ChemCheck",
  "webDir": "dist",
  "server": {
    "hostname": "localhost",
    "androidScheme": "https",
    "iosScheme": "capacitor",
    "allowNavigation": [
      "*.clerk.accounts.dev",
      "*.clerk.com",
      "clerk.chemcheck.xyz",
      "*.convex.cloud",
      "challenges.cloudflare.com"
    ]
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "cordova": {
    "preferences": {
      "CordovaWebViewEngine": "WKWebView",
      "WKWebViewOnly": "true"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0f172a",
    "limitsNavigationsToAppBoundDomains": false
  }
}