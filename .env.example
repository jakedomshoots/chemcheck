# =============================================================================
# ChemCheck Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# NEVER put secret keys in VITE_ variables — they'll be visible in client code.
# =============================================================================

# -----------------------------------------------------------------------------
# CRITICAL — App will not start without these
# -----------------------------------------------------------------------------

# Convex backend URL (e.g., https://happy-animal-123.convex.cloud)
VITE_CONVEX_URL=

# Clerk publishable key (e.g., pk_test_... or pk_live_...)
VITE_CLERK_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# IMPORTANT — Features degrade without these but app still works
# -----------------------------------------------------------------------------

# Clerk domain configuration
VITE_CLERK_DOMAIN=
VITE_CLERK_PROXY_URL=

# Stripe billing (publishable key and price IDs)
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_CHECKOUT_URL=
VITE_STRIPE_PORTAL_URL=
VITE_STRIPE_CANCEL_URL=
VITE_STRIPE_STARTER_PRICE_ID=
VITE_STRIPE_PRO_PRICE_ID=
VITE_STRIPE_BUSINESS_PRICE_ID=

# Google Analytics measurement ID (e.g., G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Sentry DSN for error tracking
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# BUILD ONLY — Set in CI/CD or Vercel environment, not in .env.local
# -----------------------------------------------------------------------------

# Sentry source map upload (production builds only)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Convex deployment key (set in Vercel for auto-deploy)
CONVEX_DEPLOY_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Development / feature flags
# -----------------------------------------------------------------------------

# Show placeholder labels in Settings UI (set to "true" to enable)
VITE_SHOW_PLACEHOLDERS=

# iOS simulator auth bypass — DEV ONLY! Never set in production.
VITE_IOS_SIM_AUTH_BYPASS=